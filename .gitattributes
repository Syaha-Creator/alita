# Auto-detect text files and normalise line endings (LF in repo, native on checkout)
* text=auto

# Force LF for scripts (even on Windows)
*.sh text eol=lf

# Binary files — never touch
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.jar binary
*.keystore binary
*.jks binary
