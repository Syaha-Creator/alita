# ──────────────────────────────────────────────────────────────
# Alita Pricelist — Environment Variables
# ──────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in the actual values.
# NEVER commit the real `.env` file to version control.
#
# SETUP FIREBASE (required after fresh clone):
#   1. Install FlutterFire CLI:  dart pub global activate flutterfire_cli
#   2. Run:  flutterfire configure
#      This generates: lib/firebase_options.dart,
#      android/app/google-services.json, ios/Runner/GoogleService-Info.plist
# ──────────────────────────────────────────────────────────────

# Alita (Ruby) API
API_BASE_URL=https://your-api-domain.com/api

# OAuth client credentials — WAJIB keduanya terisi untuk platform yang Anda jalankan.
# AppConfig memilih pasangan berdasarkan OS: Android vs iOS memakai key BERBEDA.
# Jika hanya CLIENT_ID_ANDROID yang diisi, build iOS/Simulator akan gagal "konfigurasi tidak lengkap".

# Android (flutter run -d android / APK)
CLIENT_ID_ANDROID=your_android_client_id
CLIENT_SECRET_ANDROID=your_android_client_secret

# iOS (flutter run -d ios / Xcode) — harus terisi tersendiri, bukan menyalin dari Android kecuali backend mengizinkan sama
CLIENT_ID_IOS=your_ios_client_id
CLIENT_SECRET_IOS=your_ios_client_secret

# Comforta API (Brand Spec)
COMFORTA_API_HOST=comforta.co.id
COMFORTA_ACCESS_TOKEN=your_comforta_access_token
COMFORTA_CLIENT_ID=your_comforta_client_id
COMFORTA_CLIENT_SECRET=your_comforta_client_secret

# Region API (Indonesian Administrative Data)
REGION_API_BASE_URL=https://www.emsifa.com/api-wilayah-indonesia/api

# Firebase Configuration (for Cloud Functions / Admin SDK)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
FIREBASE_CLIENT_ID=
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token
FIREBASE_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
FIREBASE_CLIENT_X509_CERT_URL=
FIREBASE_UNIVERSE_DOMAIN=googleapis.com
