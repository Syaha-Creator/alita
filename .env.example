# ──────────────────────────────────────────────────────────────
# Alita Pricelist — Environment Variables
# ──────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in the actual values.
# NEVER commit the real `.env` file to version control.
# ──────────────────────────────────────────────────────────────

# Alita (Ruby) API
API_BASE_URL=https://your-api-domain.com/api
CLIENT_ID=your_client_id_here
CLIENT_SECRET=your_client_secret_here

# Comforta API (Brand Spec)
COMFORTA_API_HOST=comforta.co.id
COMFORTA_ACCESS_TOKEN=your_comforta_access_token
COMFORTA_CLIENT_ID=your_comforta_client_id
COMFORTA_CLIENT_SECRET=your_comforta_client_secret

# Region API (Indonesian Administrative Data)
REGION_API_BASE_URL=https://www.emsifa.com/api-wilayah-indonesia/api

# Firebase Configuration (for Cloud Functions / Admin SDK)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
FIREBASE_CLIENT_ID=
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token
FIREBASE_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
FIREBASE_CLIENT_X509_CERT_URL=
FIREBASE_UNIVERSE_DOMAIN=googleapis.com
