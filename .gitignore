# ──────────────────────────────────────────────────────────────
# Alita Pricelist — .gitignore
# ──────────────────────────────────────────────────────────────

# ─── OS Generated ─────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
*~

# ─── IDE / Editor ────────────────────────────────────────────
*.iml
*.ipr
*.iws
.idea/
.vscode/
*.swp
*.swo
.*.swp

# Cursor IDE (keep .cursor/rules/ for shared workspace rules)
.cursor/*
!.cursor/rules/

# ─── Flutter / Dart / Pub ────────────────────────────────────
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
*.dill
*.dill.track.dill
.metadata
.packages

# FVM (Flutter Version Manager)
.fvm/flutter_sdk
.fvm/fvm_config.json

# ─── Environment & Secrets ───────────────────────────────────
.env
.env.*
!.env.example
*.keystore
*.jks

# ─── Android ─────────────────────────────────────────────────
/android/app/debug/
/android/app/profile/
/android/app/release/
/android/app/build/
/android/app/.cxx/
/android/build/
/android/.gradle/
/android/local.properties
android/local.properties
android/key.properties
android/app/key.properties
android/.gradle/
android/.kotlin/
android/app/.cxx/

# Android build outputs
*.apk
*.aab

# ─── iOS / Xcode ─────────────────────────────────────────────
ios/Pods/
ios/.symlinks/
ios/Flutter/ephemeral/
ios/Flutter/Flutter.framework
ios/Flutter/Flutter.podspec
ios/Flutter/Generated.xcconfig
ios/Flutter/flutter_export_environment.sh
ios/Flutter/Debug.xcconfig
ios/Flutter/Release.xcconfig
ios/build/
**/xcuserdata/
**/xcshareddata/
*.xcuserdatad
*.xcuserstate

# iOS build outputs
*.ipa

# ─── Web ─────────────────────────────────────────────────────
# web/ folder is intentionally tracked for Flutter web support

# ─── Firebase Cloud Functions ────────────────────────────────
functions/node_modules/
functions/.env
functions/lib/

# ─── Symbolication & Obfuscation ────────────────────────────
app.*.symbols
app.*.map.json

# ─── Testing & Coverage ─────────────────────────────────────
coverage/
*.lcov
test/.test_runner.dart

# ─── Build & Temp ────────────────────────────────────────────
*.tmp
*.temp
*.log
*.class
*.pyc

# ─── Firebase Credentials (NEVER commit real keys) ──────────
# These contain API keys that GitHub Secret Scanning will flag.
# Regenerate with: flutterfire configure
lib/firebase_options.dart
android/app/google-services.json
ios/Runner/GoogleService-Info.plist

# Firebase project config (safe to track, no secrets)
# firebase.json                      → tracked intentionally
# .firebaserc                        → tracked intentionally
